# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright artifacts
/playwright-report/
/test-results/

# local agent/runtime state
/.omo/
apps/android/.omo/
/.omx/
/.sisyphus/
/.playwright-mcp/
/.gjc/

# ad-hoc QA screenshots
/btape-*.png
/[0-9][0-9]-*.png
/auto-install-*.png
/manual-qa-*.png

# Electron build output
/dist-electron/

# mobile native evidence
apps/android/evidence/
apps/ios/BananaTape/TestEvidence/
apps/ios/BananaTape/iOSReviewEvidence/

# QA screenshots and artifacts
/artifacts/
